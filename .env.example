# .env.example

# Backend Server Configuration

PORT=3000

# AI API Keys
ZHIPU_API_KEY=your_zhipu_api_key_here

# Aliyun OSS Configuration
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_OSS_BUCKET_NAME=your_bucket_name_here
ALIYUN_OSS_ENDPOINT=your_endpoint_here

# MongoDB Configuration
MONGODB_URI=mongodb://your_mongo_user:your_mongo_password@your_mongo_host:27017/your_database_name_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Frontend URL
FRONTEND_URL=http://your_frontend_url_here